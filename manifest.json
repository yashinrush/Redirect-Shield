{
  "manifest_version": 3,
  "name": "NexShield",
  "version": "2.0.0",
  "description": "An AI-enhanced security extension blocking malicious popups, deceptive redirects, transparent overlays, and fake download buttons.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "utils/logger.js",
        "utils/storage.js",
        "utils/helpers.js",
        "utils/rules.js",
        "utils/detector.js",
        "utils/overlay.js",
        "utils/toast.js",
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "NexShield"
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "toggle-protection": {
      "suggested_key": {
        "default": "Ctrl+Shift+B"
      },
      "description": "Toggle NexShield Protection state"
    }
  }
}
